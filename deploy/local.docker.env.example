# Example root .env for docker compose (copy to repo root as `.env`).
# Postgres must be reachable from containers: use host.docker.internal on Mac/Win, or the host LAN IP on Linux.

# --- API + Django (shared) ---
DATABASE_URL=postgresql+psycopg://ryunova:ryunova@host.docker.internal:5432/ryunova
DJANGO_SECRET_KEY=change-me-local-only
DEBUG=false
USE_WHITENOISE=true
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8011,http://localhost:8011

RYUNOVA_API_BASE=http://api:8010/api/v1
RYUNOVA_API_PUBLIC=http://127.0.0.1:8010
RYUNOVA_API_PUBLIC_PORT=8010
SITE_URL=http://127.0.0.1:8011
SITE_DOMAIN=127.0.0.1:8011

# Published host ports (match docker-compose.app-only.yml defaults)
RYUNOVA_API_PORT=8010
RYUNOVA_WEB_PORT=8011
