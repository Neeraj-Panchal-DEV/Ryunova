# =============================================================================
# EC2 / Docker production — not for local laptops (see docs/ENVIRONMENT.md).
# =============================================================================
# Single .env for api + web containers. Django calls FastAPI internally:
#   RYUNOVA_API_BASE=http://api:8010/api/v1

# --- FastAPI (public URLs in JSON) ------------------------------------------
# Single-level hostname (e.g. ryunova-api.latrobecomputing.co.in) matches *.latrobecomputing.co.in
API_PUBLIC_URL=https://ryunova-api.yourdomain.com
SITE_URL=https://app.yourdomain.com
SITE_DOMAIN=app.yourdomain.com
DATABASE_URL=postgresql+psycopg://USER:PASS@host.docker.internal:5432/latrobe_apps_db
SECRET_KEY=long-random-string
CORS_ORIGINS=https://app.yourdomain.com,http://127.0.0.1:8011

# --- Django -----------------------------------------------------------------
DJANGO_SECRET_KEY=long-random-string
DEBUG=false
USE_WHITENOISE=true
USE_TLS_BEHIND_PROXY=true
RYUNOVA_API_BASE=http://api:8010/api/v1
RYUNOVA_API_PUBLIC=https://ryunova-api.yourdomain.com
RYUNOVA_API_PUBLIC_PORT=443
RYUNOVA_REWRITE_API_PUBLIC_IN_RESPONSES=false
ALLOWED_HOSTS=app.yourdomain.com,ryunova-api.yourdomain.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com,https://ryunova-api.yourdomain.com

# S3 (optional; set USE_S3_MEDIA=true + instance IAM for PutObject/DeleteObject/GetObject)
AWS_S3_MEDIA_BUCKET=ryunova-channels-organisations-media
AWS_S3_REGION=ap-southeast-2
USE_S3_MEDIA=false
# Empty when USE_S3_MEDIA=false. When true, deploy sets bucket URL unless you override (CloudFront).
MEDIA_PUBLIC_BASE_URL=

# --- SMTP (optional) --------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_HOST_USER_NAME=RyuNova Platform
