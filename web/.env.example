# =============================================================================
# RyuNova Django web — copy to web/.env (never commit real secrets)
# =============================================================================
# Use one file per environment: local laptop vs production server.
# See docs/ENVIRONMENT.md for how this pairs with backend/.env.

# --- Local vs production (examples) ------------------------------------------
# LOCAL:   DEBUG=true
# SERVER:  DEBUG=false
DEBUG=true

# Django session secret (generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))")
# SECRET_KEY=...

# Hosts / CSRF (LAN: add http://192.168.x.x:8001 )
# ALLOWED_HOSTS=127.0.0.1,localhost,*
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001

# --- FastAPI backend URL (browser / server must reach this) -----------------
RYUNOVA_API_BASE=http://127.0.0.1:8000/api/v1
# EC2 Docker: set to http://api:8010/api/v1 so Django talks to FastAPI on the internal network (see deploy/ec2.env.example).
# RYUNOVA_API_BASE_INTERNAL=http://api:8010/api/v1
RYUNOVA_API_PUBLIC=http://127.0.0.1:8000
# RYUNOVA_API_PUBLIC_PORT=8000
# RYUNOVA_REWRITE_API_PUBLIC_IN_RESPONSES=true

# --- Public site URL (invitation links, emails) -----------------------------
# LOCAL:
SITE_DOMAIN=127.0.0.1:8001
# SITE_URL=http://127.0.0.1:8001
# SERVER (example):
# SITE_DOMAIN=app.example.com
# SITE_URL=https://app.example.com

# --- SMTP (Hostinger-style; same names as FinText) --------------------------
# Leave USER/PASSWORD empty to use Django console email backend (dev only).
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
# EMAIL_HOST_USER=no_reply@latrobecomputing.co.in
# EMAIL_HOST_PASSWORD=9Oq^Izkvy
# DEFAULT_FROM_EMAIL=no_reply@latrobecomputing.co.in
# EMAIL_HOST_USER_NAME="RyuNova Platform"
# EMAIL_TIMEOUT=25
# EMAIL_LOGO_URL=

# --- Cloudflare Turnstile (login anti-bot; optional) -----------------------------
# Step-by-step: docs/TURNSTILE.md (repo root). If BOTH are set, password + email-code login use
# Turnstile instead of the built-in quiz. Create keys: https://dash.cloudflare.com/ → Turnstile.
# Use "Managed" widget; add hostnames users type in the browser (e.g. 127.0.0.1, localhost, app.example.com).
# TURNSTILE_SITE_KEY=0x4AAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAA...
